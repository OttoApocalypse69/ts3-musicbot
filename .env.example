# ==============================================================================
# TS3 Music Bot Environment Configuration Template
# Copy this file to '.env' and fill in your details before running docker-compose.
# Never check your final '.env' file containing secrets into source control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. TeamSpeak 3 Server Connection Settings
# ------------------------------------------------------------------------------
# Server address to connect to (IP or hostname)
TS3_SERVER_ADDRESS=your.teamspeak-server.com

# Server port (default is 9987)
TS3_SERVER_PORT=9987

# Server password (leave blank if none)
TS3_SERVER_PASSWORD=

# The nickname of the music bot inside the server channels
TS3_NICKNAME=MusicBot

# Target channel name the bot should connect to upon joining
TS3_CHANNEL_NAME=Music Channel

# Channel password (leave blank if none)
TS3_CHANNEL_PASSWORD=

# Path to local channel.txt (optional, keep blank for automatic resolution)
TS3_CHANNEL_FILE_PATH=

# Accept TeamSpeak 3 Client License (Must be true to run)
TS3_ACCEPT_TS_LICENSE=true

# Use the official TS3 Client under the hood. Keep true for audio playback compatibility.
TS3_USE_OFFICIAL_TSCLIENT=true

# ClientQuery API Key (leave empty; official client automatically generates one at startup)
TS3_API_KEY=

# ------------------------------------------------------------------------------
# 2. Spotify Settings (Only needed for Spotify playback)
# ------------------------------------------------------------------------------
# Spotify player client to use under the hood (disabled, spotify, ncspot, spotify_player, spotifyd)
# Keep disabled unless you have Spotify Premium and want Spotify playback.
TS3_SPOTIFY_PLAYER=disabled

# Spotify Premium Account Credentials
TS3_SPOTIFY_USERNAME=your_spotify_username
TS3_SPOTIFY_PASSWORD=your_spotify_password

# Country/Market code (e.g. US, DE, FR)
TS3_MARKET=US

# Base64 encoded ClientID:ClientSecret (Optional, used if you have a custom Spotify developer app)
TS3_SP_API_KEY=

# Custom Developer App details (Optional, alternatively generated via client ID and secret)
TS3_SP_CLIENT_ID=
TS3_SP_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# 3. Media Streaming & API configurations
# ------------------------------------------------------------------------------
# YouTube Developer API Key (Optional: helps avoid HTTP 403 API quota blocks)
TS3_YT_API_KEY=

# ------------------------------------------------------------------------------
# 4. Default Playback Volume (0 - 100)
# ------------------------------------------------------------------------------
TS3_SC_VOLUME=50
TS3_YT_VOLUME=50
TS3_BC_VOLUME=50

# ------------------------------------------------------------------------------
# 5. Permissions
# ------------------------------------------------------------------------------
# Leave these blank to let everyone use the bot.
# Add comma-separated nicknames or TeamSpeak group IDs only if you want restrictions.
#
# Music permission controls who can add songs with !play / queue add commands.
# Blank means everyone can add music.
TS3_MUSIC_PERMISSION_NICKNAMES=
TS3_MUSIC_PERMISSION_SERVER_GROUPS=
TS3_MUSIC_PERMISSION_CHANNEL_GROUPS=

# Admin/control permission controls restricted admin actions when configured.
# Blank means everyone can use normal control commands.
TS3_ADMIN_PERMISSION_NICKNAMES=
TS3_ADMIN_PERMISSION_SERVER_GROUPS=
TS3_ADMIN_PERMISSION_CHANNEL_GROUPS=

# Optional always-admin nicknames. Leave blank unless you want owner-only controls.
TS3_OWNER_NICKNAMES=

# Optional anti-spam cooldown. Set to 0 to disable.
TS3_COMMAND_COOLDOWN_SECONDS=3

# ------------------------------------------------------------------------------
# 6. Optional Command Aliases
# ------------------------------------------------------------------------------
# Default commands use the ! prefix, for example:
#   !play never gonna give you up
#   !queue
#   !skip
#
# These values are optional. Override them only if you want different names.
#
# TS3_COMMAND_PREFIX=!
# TS3_HELP_COMMAND=help
# TS3_PLAY_COMMAND=play
# TS3_QUEUE_ADD_COMMAND=queue-add
# TS3_QUEUE_PLAYNEXT_COMMAND=queue-playnext
# TS3_QUEUE_PLAYNOW_COMMAND=queue-playnow
# TS3_QUEUE_PLAY_COMMAND=queue-play
# TS3_QUEUE_REPEAT_COMMAND=queue-repeat
# TS3_HEALTH_COMMAND=health
# TS3_SEEK_COMMAND=seek
# TS3_HISTORY_COMMAND=history
# TS3_REPLAY_COMMAND=replay
# TS3_LOOP_COMMAND=loop
# TS3_LOOP_QUEUE_COMMAND=loopqueue
# TS3_LOOP_OFF_COMMAND=loopoff
# TS3_LOOP_STATUS_COMMAND=loopstatus
# TS3_VOLUME_COMMAND=volume
# TS3_VOLUME_SHORT_COMMAND=vol
# TS3_INFO_COMMAND=info
# TS3_SEARCH_COMMAND=search
# TS3_GOTO_COMMAND=goto
# TS3_RETURN_COMMAND=return

